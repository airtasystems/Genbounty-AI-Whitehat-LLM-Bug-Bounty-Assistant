# Copy to .env and fill in values.
# Required for generate + security-assess (Gemini).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_JUDGE=

# Optional: auto-select site/component on web UI startup (skips Manage modal)
# TARGET may be a full URL or host:port; it is normalized to the site id under browser-bot/sites/
# TARGET=http://localhost:3000
# COMPONENT=chat

# Optional: AIRTA Systems export (Export tab)
# GENBOUNTY_HOST=
# GENBOUNTY_API_KEY=
# GENBOUNTY_USER_ID=
# GENBOUNTY_EXPORT_SCHEMA=security   # security (default) | legacy
# GENBOUNTY_IMPORT_PATH=            # override path, e.g. /api/v2/imported-reports/company
# GENBOUNTY_DEFAULT_SEVERITY=indeterminate
# GENBOUNTY_EXPORT_BATCH_SIZE=25    # results per POST (default 25; was 2500)
# GENBOUNTY_EXPORT_DELAY_SECONDS=2  # pause between batches and multi-report exports
# GENBOUNTY_EXPORT_MAX_RETRIES=6    # retries on 429 / rate limit
# GENBOUNTY_EXPORT_RETRY_BASE_SECONDS=5

# Optional: assessment concurrency
# SECURITY_ASSESS_CONCURRENCY=1

# Optional: multimodal payload output directory (default: payloads/generate/)
# PAYLOADS_OUTPUT_DIR=payloads/generate
